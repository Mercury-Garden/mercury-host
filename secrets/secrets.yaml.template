---
# secrets.yaml.template — PLACEHOLDER VERSION of the secrets backup file.
#
# This file is committed to the repo (sanitized). The real version lives
# at /home/ubuntu/.secrets/secrets.yaml (mode 0600) and is regenerated by
# `bash scripts/backup-secrets.sh`. The real file is NEVER committed.
#
# Every value below is replaced with a `<set from ...>` placeholder that
# points at the source on the live host. On a fresh host, populate a
# real secrets.yaml by copying a real backup:
#
#   scp mercury:.secrets/secrets.yaml ~/.secrets/
#
# (There is no `--from-template` flag — the template has placeholder
#  values, not real ones, so a template-based restore would put the
#  placeholders onto the live filesystem. Always restore from a real
#  backup, never from this template.)
#
# What each value represents (see scripts/backup-secrets.sh for the
# capture logic and scripts/restore-secrets.sh for the inverse):
#
#   ssh_ed25519_private        ~/.ssh/id_ed25519                    (mode 0600)
#   ssh_ed25519_public         ~/.ssh/id_ed25519.pub                (mode 0644)
#   gh_hosts_yml               ~/.config/gh/hosts.yml               (mode 0600)
#   gh_token_env               ~/.hermes/.env → GITHUB_TOKEN value (default profile)
#   oauth2_client_secret       ~/.config/oauth2-proxy/oauth2-proxy.cfg → client_secret
#   oauth2_cookie_secret       ~/.config/oauth2-proxy/oauth2-proxy.cfg → cookie_secret
#   hermes_env                 ~/.hermes/.env                       (mode 0600, default profile)
#   hermes_profile_<name>_env  ~/.hermes/profiles/<name>/.env       (mode 0600, per-profile, auto-discovered)
#   gh_token_env_profile_<name> ~/.hermes/profiles/<name>/.env → GITHUB_TOKEN value (per-profile)
#   goose_secrets              ~/.config/goose/secrets.yaml         (mode 0600)
#   letsencrypt_account_key    /etc/letsencrypt/accounts/.../account_key.json
#   letsencrypt_privkey        /etc/letsencrypt/live/mercury.garden/privkey.pem
#   mercury_tasks_tokens       /home/ubuntu/.config/mercury-tasks/tokens.json  (mode 0600)
#   x_digest_env               ~/data/code/x-digest/.env            (mode 0600)  [alias]
#   scriptcaster_env           ~/data/code/scriptcaster/.env        (mode 0600)  [alias]
#   code_env_<sanitized-path>  EVERY .env* file under ~/data/code/  (mode 0600)
#                              except *.example / *.sample templates.
#                              See "Auto-discovered ~/data/code/**/*.env"
#                              section below. Adding a new project with a .env
#                              needs NO edit to backup-secrets.sh, this template,
#                              or inventory.yaml — discovery is automatic at
#                              backup time. Restore one with:
#                                bash scripts/restore-secrets.sh --env <path>
#                              or all with:
#                                bash scripts/restore-secrets.sh --include code-env
#   openchamber-startup-env    /home/ubuntu/.config/openchamber/startup.env   (mode 0600)
#   opencode-auth              ~/.local/share/opencode/auth.json               (mode 0600)
#   discord-notify             ~/.config/discord-notify/config.yaml            (mode 0600)
#   gogcli                     ~/.config/gogcli/credentials.json + keyring/    (mode 0600)
#   webhook-server             ~/.config/webhook-server/secret.txt + projects.yaml
#                                                                              (mode 0600)
#   openviking_minimax_api_key ~/.openviking/.minimax-key                      (mode 0600)  [DEPRECATED 2026-07-24; kept for rollback]
#   openviking_openrouter_api_key  ~/.hermes/.env → OPENROUTER_API_KEY value   (scalar, default-profile Hermes .env)
#   openviking_ov_conf         ~/.openviking/ov.conf                           (mode 0600, uses ${OPENROUTER_API_KEY} substitution)
#
# Rotation policy: see /home/ubuntu/data/code/mercury-host/secrets/inventory.yaml
# (in this same repo, secrets/inventory.yaml).

# ── SSH ────────────────────────────────────────────────────────────────
ssh_ed25519_private: |
  <set from live host: ~/.ssh/id_ed25519, base64-decoded>
ssh_ed25519_public: |
  <set from live host: ~/.ssh/id_ed25519.pub, base64-decoded>

# ── GitHub ──────────────────────────────────────────────────────────────
gh_hosts_yml: |
  <set from live host: ~/.config/gh/hosts.yml, base64-decoded>
gh_token_env: "<set from live host: ~/.hermes/.env GITHUB_TOKEN value>"

# ── oauth2-proxy ────────────────────────────────────────────────────────
oauth2_client_secret: "<set from live host: ~/.config/oauth2-proxy/oauth2-proxy.cfg client_secret>"
oauth2_cookie_secret: "<set from live host: ~/.config/oauth2-proxy/oauth2-proxy.cfg cookie_secret>"

# ── Hermes ──────────────────────────────────────────────────────────────
# Default profile (the one that runs the user-facing gateway). Per-profile
# .env files under ~/.hermes/profiles/<name>/.env are auto-discovered by
# backup-secrets.sh and emitted as `hermes_profile_<name>_env` blocks below
# (no inventory edit needed when a new profile is created). Each per-profile
# block also surfaces its `GITHUB_TOKEN` value as
# `gh_token_env_profile_<name>` so a restore can put the right token in the
# right file even if the profile's .env is otherwise empty.
hermes_env: |
  <set from live host: ~/.hermes/.env, base64-decoded>
# Example per-profile block (copy as needed; backup-secrets.sh emits these
# automatically for every ~/.hermes/profiles/<name>/.env it finds):
#hermes_profile_mercury-butler_env: |
#  <set from live host: ~/.hermes/profiles/mercury-butler/.env, base64-decoded>
#gh_token_env_profile_mercury-butler: "<set from live host: ~/.hermes/profiles/mercury-butler/.env GITHUB_TOKEN value>"

# ── Goose ───────────────────────────────────────────────────────────────
goose_secrets: |
  <set from live host: ~/.config/goose/secrets.yaml, base64-decoded>

# ── Letsencrypt ─────────────────────────────────────────────────────────
letsencrypt_account_key_path: "<set from live host: certbot account_key.json path>"
letsencrypt_account_key: |
  <set from live host: account_key.json, base64-decoded>
letsencrypt_privkey_path: "<set from live host: /etc/letsencrypt/live/mercury.garden/privkey.pem>"
letsencrypt_privkey_real_path: "<set from live host: /etc/letsencrypt/archive/mercury.garden/privkeyN.pem>"
letsencrypt_privkey: |
  <set from live host: privkey.pem, base64-decoded>

# ── mercury-tasks ───────────────────────────────────────────────────────
mercury_tasks_tokens: |
  <set from live host: /home/ubuntu/.config/mercury-tasks/tokens.json, base64-decoded>

# ── x-digest ────────────────────────────────────────────────────────────
# Back-compat alias for code_env_x-digest_env (see auto-discovered section
# below). Still emitted so existing restore --include x-digest invocations
# keep working. The auto-discovered section is the authoritative capture;
# this block is intentionally redundant so a partial-restore from an older
# secrets.yaml still recovers x-digest.
x_digest_env: |
  <set from live host: ~/data/code/x-digest/.env, base64-decoded>

# ── scriptcaster ────────────────────────────────────────────────────────
# Back-compat alias for code_env_scriptcaster_env (see auto-discovered
# section below). Same rationale as x_digest_env above.
scriptcaster_env: |
  <set from live host: ~/data/code/scriptcaster/.env, base64-decoded>

# ── Auto-discovered ~/data/code/**/*.env (excluding *.example) ──────────
# Added 2026-07-07 (feat/secrets-auto-discover-code-env). Each `.env*` file
# under ~/data/code/ — except templates like `*.example` / `*.sample` that
# never have real secrets — is captured as a `code_env_<sanitized-path>` b64
# block. The path → key mapping is computed by sanitize_env_kind() in
# backup-secrets.sh: strip the $HOME/data/code/ prefix, lowercase, replace
# `/` and `.` with `_`, drop everything not [a-z0-9_-], prepend `code_env_`.
# Example: ~/data/code/mercury-tasks/web/.env.production
#        → code_env_mercury-tasks_web_env_production
# The lines below are EXAMPLE blocks. A real backup will list every .env*
# currently on disk — the count grows/shrinks as projects are added/removed.
# Restoring one file:
#   bash scripts/restore-secrets.sh --env x-digest/.env
# Restoring all auto-discovered files:
#   bash scripts/restore-secrets.sh --include code-env
code_env_x-digest_env: |
  <set from live host: ~/data/code/x-digest/.env, base64-decoded>
code_env_scriptcaster_env: |
  <set from live host: ~/data/code/scriptcaster/.env, base64-decoded>
code_env_mercury-tasks_web_env_production: |
  <set from live host: ~/data/code/mercury-tasks/web/.env.production, base64-decoded>

# ── openchamber ─────────────────────────────────────────────────────────
openchamber_startup_env: |
  <set from live host: /home/ubuntu/.config/openchamber/startup.env, base64-decoded>

# ── opencode auth (provider API keys) ───────────────────────────────────
# Contains 3 provider API keys: opencode-go, minimax-coding-plan, openrouter.
opencode_auth: |
  <set from live host: ~/.local/share/opencode/auth.json, base64-decoded>

# ── discord-notify (per-project HMAC + chat IDs) ───────────────────────
# The notifySecret values here MUST match the matching fields in
# ~/.config/webhook-server/projects.yaml.
discord_notify_config: |
  <set from live host: ~/.config/discord-notify/config.yaml, base64-decoded>

# ── gogcli (Gmail OAuth client creds + encrypted keyring) ───────────────
# Restoring the keyring requires GOG_KEYRING_PASSWORD from the hermes
# .env block above to decrypt the 3 encrypted blobs.
gogcli_credentials: |
  <set from live host: ~/.config/gogcli/credentials.json, base64-decoded>
gogcli_keyring_tar_gz: |
  <set from live host: ~/.config/gogcli/keyring/ packed as tar.gz, base64-decoded>

# ── webhook-server (HMAC signing key + per-project secrets) ─────────────
# secret.txt is the global HMAC signing key (verifies GitHub webhook
# payloads). projects.yaml carries per-project notifyUrl + notifySecret
# values that must match the corresponding entries in
# ~/.config/discord-notify/config.yaml.
webhook_server_secret: |
  <set from live host: ~/.config/webhook-server/secret.txt, base64-decoded>
webhook_server_projects: |
  <set from live host: ~/.config/webhook-server/projects.yaml, base64-decoded>

# ── openviking (added 2026-07-19; OpenRouter migration 2026-07-24) ──────
# Three blocks cover the OpenViking subsystem:
#   * openviking_minimax_api_key    — DEPRECATED 2026-07-24. The standalone
#                                    key file at ~/.openviking/.minimax-key
#                                    is no longer read by OpenViking
#                                    (ov.conf is OpenRouter-anchored) but
#                                    kept for 7-day rollback window.
#   * openviking_openrouter_api_key — the live key. Scalar value sourced
#                                    from OPENROUTER_API_KEY in
#                                    ~/.hermes/.env. Restore path writes
#                                    this back as `OPENROUTER_API_KEY=...`
#                                    to ~/.hermes/.env (appending if missing,
#                                    preserving other entries).
#   * openviking_ov_conf            — the config file. Contains the
#                                    provider=openai + api_base=openrouter
#                                    + api_key="${OPENROUTER_API_KEY}"
#                                    substitution. Backed up for fresh-host
#                                    restore parity.
# Restore (single include kind covers all three):
#   bash scripts/restore-secrets.sh --include openviking
openviking_minimax_api_key: |
  <set from live host: ~/.openviking/.minimax-key, base64-decoded>
openviking_openrouter_api_key: "<set from live host: ~/.hermes/.env OPENROUTER_API_KEY value>"
openviking_ov_conf: |
  <set from live host: ~/.openviking/ov.conf, base64-decoded>

# ── Varlock pass store + GPG private key (added 2026-07-20, Stage 3) ─────
# Three blocks cover the encrypted store + key recovery:
#   * varlock_gpg_armored_private    — the durable copy. Single-file armored
#                                     export of the GPG private key (~3-5 KB).
#                                     Always emitted when Stage 2 has run.
#                                     Restored via `gpg --import`.
#   * varlock_gpg_private_tar_gz     — opportunistic second layer. tar.gz of
#                                     ~/.gnupg/private-keys-v1.d/. May be
#                                     near-empty on hosts where the agent
#                                     hasn't yet materialized .key files
#                                     (this is GnuPG 2.4.4 default behavior;
#                                     the files appear on first private-key
#                                     access). Restore merges; armored
#                                     import is the durable path.
#   * varlock_pass_store_tar_gz      — tar.gz of ~/.password-store/. Always
#                                     emitted when Stage 2 has run.
# Restore (one include covers all three):
#   bash scripts/restore-secrets.sh --include varlock-pass
# The restore uses extract_tar_gz_b64_block_preserve for the tars:
# existing files on the destination host are NOT clobbered. A backup
# from Monday doesn't destroy entries added Wednesday.
varlock_gpg_armored_private: |
  <set from live host: gpg --export-secret-keys --armor <FP>, base64-decoded>
varlock_gpg_private_tar_gz: |
  <set from live host: ~/.gnupg/private-keys-v1.d/ packed as tar.gz, base64-decoded>
varlock_pass_store_tar_gz: |
  <set from live host: ~/.password-store/ packed as tar.gz, base64-decoded>
